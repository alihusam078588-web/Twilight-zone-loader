	screenGui.Name = "CustomUILibrary"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = PlayerGui

	-- Main Frame
	local mainFrame = Instance.new("Frame")
	mainFrame.Name = "MainFrame"
	mainFrame.Size = UDim2.new(0, 500, 0, 350)
	mainFrame.Position = UDim2.new(0.5, -250, 0.5, -175)
	mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
	mainFrame.BorderSizePixel = 0
	mainFrame.Parent = screenGui

	local mainCorner = Instance.new("UICorner")
	mainCorner.CornerRadius = UDim.new(0, 8)
	mainCorner.Parent = mainFrame

	-- Top Bar (Draggable Area)
	local topBar = Instance.new("Frame")
	topBar.Name = "TopBar"
	topBar.Size = UDim2.new(1, 0, 0, 45)
	topBar.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
	topBar.BorderSizePixel = 0
	topBar.Parent = mainFrame

	local topCorner = Instance.new("UICorner")
	topCorner.CornerRadius = UDim.new(0, 8)
	topCorner.Parent = topBar

	-- Title
	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.Size = UDim2.new(1, -20, 1, 0)
	titleLabel.Position = UDim2.new(0, 15, 0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = windowTitle
	titleLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
	titleLabel.TextSize = 18
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Parent = topBar

	-- Navigation/Tab Bar
	local tabBar = Instance.new("Frame")
	tabBar.Name = "TabBar"
	tabBar.Size = UDim2.new(0, 140, 1, -45)
	tabBar.Position = UDim2.new(0, 0, 0, 45)
	tabBar.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
	tabBar.BorderSizePixel = 0
	tabBar.Parent = mainFrame

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.Padding = UDim.new(0, 5)
	tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabLayout.Parent = tabBar

	local tabPadding = Instance.new("UIPadding")
	tabPadding.PaddingTop = UDim.new(0, 10)
	tabPadding.Parent = tabBar

	-- Container for Tab Contents
	local container = Instance.new("Frame")
	container.Name = "Container"
	container.Size = UDim2.new(1, -140, 1, -45)
	container.Position = UDim2.new(0, 140, 0, 45)
	container.BackgroundTransparency = 1
	container.Parent = mainFrame

	makeDraggable(topBar, mainFrame)

	self.Container = container
	self.TabBar = tabBar
	self.Tabs = {}
	self.ActiveTab = nil

	return self
end

-- Create a Tab
function Library:CreateTab(tabTitle)
	local tabObj = {}
	
	-- Tab Button
	local tabButton = Instance.new("TextButton")
	tabButton.Name = tabTitle .. "Tab"
	tabButton.Size = UDim2.new(0.9, 0, 0, 35)
	tabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
	tabButton.Text = tabTitle
	tabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
	tabButton.Font = Enum.Font.GothamSemibold
	tabButton.TextSize = 14
	tabButton.BorderSizePixel = 0
	tabButton.AutoButtonColor = false
	tabButton.Parent = self.TabBar

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = tabButton

	-- Tab Page (Scrolling Content area)
	local tabPage = Instance.new("ScrollingFrame")
	tabPage.Name = tabTitle .. "Page"
	tabPage.Size = UDim2.new(1, 0, 1, 0)
	tabPage.BackgroundTransparency = 1
	tabPage.BorderSizePixel = 0
	tabPage.Visible = false
	tabPage.CanvasSize = UDim2.new(0, 0, 0, 0)
	tabPage.ScrollBarThickness = 4
	tabPage.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 85)
	tabPage.Parent = self.Container

	local pageLayout = Instance.new("UIListLayout")
	pageLayout.Padding = UDim.new(0, 8)
	pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
	pageLayout.Parent = tabPage

	local pagePadding = Instance.new("UIPadding")
	pagePadding.PaddingTop = UDim.new(0, 10)
	pagePadding.Parent = tabPage

	-- Auto-canvas resizing
	pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		tabPage.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 20)
	end)

	-- Tab switching logic
	local function activate()
		if self.ActiveTab then
			self.ActiveTab.Button.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
			self.ActiveTab.Button.TextColor3 = Color3.fromRGB(180, 180, 180)
			self.ActiveTab.Page.Visible = false
		end
		
		tabButton.BackgroundColor3 = Color3.fromRGB(80, 100, 240) -- Highlight Color
		tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		tabPage.Visible = true
		self.ActiveTab = tabObj
	end

	tabButton.MouseButton1Click:Connect(activate)

	-- Automatically activate the first tab created
	if not self.ActiveTab then
		activate()
	end

	tabObj.Button = tabButton
	tabObj.Page = tabPage
	
	-- Add Toggle method to the Tab
	function tabObj:CreateToggle(toggleTitle, toggleDesc, callback)
		local toggleActive = false
		callback = callback or function() end

		-- Main Toggle Frame
		local toggleFrame = Instance.new("Frame")
		toggleFrame.Name = toggleTitle .. "Toggle"
		toggleFrame.Size = UDim2.new(0.92, 0, 0, 50)
		toggleFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
		toggleFrame.BorderSizePixel = 0
		toggleFrame.Parent = tabPage

		local toggleCorner = Instance.new("UICorner")
		toggleCorner.CornerRadius = UDim.new(0, 6)
		toggleCorner.Parent = toggleFrame

		-- Title Text
		local titleText = Instance.new("TextLabel")
		titleText.Size = UDim2.new(0.7, 0, 0, 22)
		titleText.Position = UDim2.new(0, 12, 0, 6)
		titleText.BackgroundTransparency = 1
		titleText.Text = toggleTitle
		titleText.TextColor3 = Color3.fromRGB(240, 240, 240)
		titleText.Font = Enum.Font.GothamBold
		titleText.TextSize = 14
		titleText.TextXAlignment = Enum.TextXAlignment.Left
		titleText.Parent = toggleFrame

		-- Description Text
		local descText = Instance.new("TextLabel")
		descText.Size = UDim2.new(0.7, 0, 0, 16)
		descText.Position = UDim2.new(0, 12, 0, 26)
		descText.BackgroundTransparency = 1
		descText.Text = toggleDesc
		descText.TextColor3 = Color3.fromRGB(150, 150, 150)
		descText.Font = Enum.Font.Gotham
		descText.TextSize = 11
		descText.TextXAlignment = Enum.TextXAlignment.Left
		descText.Parent = toggleFrame

		-- Toggle Switch Button Outer Boundary
		local switchBg = Instance.new("TextButton")
		switchBg.Size = UDim2.new(0, 45, 0, 22)
		switchBg.Position = UDim2.new(1, -57, 0.5, -11)
		switchBg.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
		switchBg.Text = ""
		switchBg.AutoButtonColor = false
		switchBg.Parent = toggleFrame

		local switchCorner = Instance.new("UICorner")
		switchCorner.CornerRadius = UDim.new(1, 0)
		switchCorner.Parent = switchBg

		-- Switch Circle Indicator
		local indicator = Instance.new("Frame")
		indicator.Size = UDim2.new(0, 16, 0, 16)
		indicator.Position = UDim2.new(0, 3, 0.5, -8)
		indicator.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
		indicator.BorderSizePixel = 0
		indicator.Parent = switchBg

		local indCorner = Instance.new("UICorner")
		indCorner.CornerRadius = UDim.new(1, 0)
		indCorner.Parent = indicator

		-- Interactive Toggle Click
		switchBg.MouseButton1Click:Connect(function()
			toggleActive = not toggleActive
			
			local goalColor = toggleActive and Color3.fromRGB(80, 100, 240) or Color3.fromRGB(50, 50, 55)
			local goalPos = toggleActive and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)

			TweenService:Create(switchBg, TweenInfo.new(0.2), {BackgroundColor3 = goalColor}):Play()
			TweenService:Create(indicator, TweenInfo.new(0.2), {Position = goalPos}):Play()

			task.spawn(callback, toggleActive)
		end)
	end

	return tabObj
end

return Library
